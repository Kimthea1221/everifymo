{
  "manifest_version": 3,
  "name": "E-VERIFYMO",
  "version": "1.0",
  "description": "Real-time FDA product verification for Philippine e-commerce platforms.",

  "action": {
    "default_popup": "popup/popup.html"
  },

  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "https://shopee.ph/*",
    "https://www.lazada.com.ph/*",
    "https://www.tiktok.com/*",
    "https://www.facebook.com/marketplace/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://shopee.ph/*",
        "https://www.lazada.com.ph/*",
        "https://www.tiktok.com/*",
        "https://www.facebook.com/marketplace/*"
      ],
      "js": ["scripts/content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "scripts/background.js"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "pages/auth.html",
        "pages/report-status.html",
        "css/*.css",
        "js/*.js",
        "assets/fonts/*.woff2",
        "assets/icons/*.png",
        "assets/images/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}