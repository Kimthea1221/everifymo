# Used by the running FastAPI app at runtime — restricted role, RLS-respecting
DATABASE_URL=postgresql://everify_app:your_app_password@localhost:5432/everify_db

# Used only by Alembic migrations — owner/superuser role, bypasses RLS
MIGRATIONS_DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/everify_db

SECRET_KEY=